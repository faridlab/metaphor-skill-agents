#!/bin/bash
# {{ module_name|title }} Integration Test Runner
#
# Runs comprehensive integration tests for {{ module_name }} module
# Following Backbone Framework testing patterns

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

MODULE_NAME="{{ module_name }}"
PROJECT_ROOT="{{ project_root|default("..") }}"
RESULTS_DIR="results"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
TEST_RESULTS_DIR="${RESULTS_DIR}/${MODULE_NAME}_${TIMESTAMP}"

echo -e "${BLUE}🚀 Starting ${MODULE_NAME^} Integration Tests${NC}"
echo -e "${BLUE}📊 Results will be saved to: ${TEST_RESULTS_DIR}${NC}"

# Create results directory
mkdir -p "${TEST_RESULTS_DIR}"

# Set environment variables
export DATABASE_URL="${DATABASE_URL:-postgresql://root:password@localhost:5432/monorepodb}"
export API_BASE_URL="${API_BASE_URL:-http://127.0.0.1:3001}"
export TEST_RESULTS_DIR="${TEST_RESULTS_DIR}"
export TEST_VERBOSE="${TEST_VERBOSE:-false}"
export CLEANUP_AFTER_TESTS="${CLEANUP_AFTER_TESTS:-true}"

echo -e "${BLUE}⚙️  Configuration:${NC}"
echo -e "  Database: ${DATABASE_URL}"
echo -e "  API URL: ${API_BASE_URL}"
echo -e "  Verbose: ${TEST_VERBOSE}"
echo -e "  Cleanup: ${CLEANUP_AFTER_TESTS}"

# Check if server is running
echo -e "\n${YELLOW}🔍 Checking API server availability...${NC}"
if curl -s "${API_BASE_URL}/health" > /dev/null 2>&1; then
    echo -e "${GREEN}✅ API server is running${NC}"
else
    echo -e "${RED}❌ API server is not running at ${API_BASE_URL}${NC}"
    echo -e "${YELLOW}Please start the API server first:${NC}"
    echo -e "  DATABASE_URL=\"${DATABASE_URL}\" cargo run -p backbone-app -- server"
    exit 1
fi

# Check database connection
echo -e "${YELLOW}🔍 Checking database connection...${NC}"
if PGPASSWORD=password psql -h localhost -U root -d monorepodb -c "SELECT 1;" > /dev/null 2>&1; then
    echo -e "${GREEN}✅ Database connection successful${NC}"
else
    echo -e "${RED}❌ Database connection failed${NC}"
    echo -e "${YELLOW}Please check database configuration and ensure PostgreSQL is running${NC}"
    exit 1
fi

# Run integration tests
echo -e "\n${BLUE}🧪 Running integration tests...${NC}"

# Run the {{ module_name }} integration tests
if cargo test --test {{ module_name }}_integration_tests 2>&1 | tee "${TEST_RESULTS_DIR}/test_output.log"; then
    echo -e "\n${GREEN}✅ All tests passed!${NC}"
    TEST_EXIT_CODE=0
else
    echo -e "\n${RED}❌ Some tests failed!${NC}"
    TEST_EXIT_CODE=1
fi

# Generate test report
echo -e "\n${YELLOW}📋 Generating test report...${NC}"

if [ -f "${TEST_RESULTS_DIR}/test_output.log" ]; then
    # Count test results from log
    PASSED_TESTS=$(grep -c "✅" "${TEST_RESULTS_DIR}/test_output.log" || echo "0")
    FAILED_TESTS=$(grep -c "❌" "${TEST_RESULTS_DIR}/test_output.log" || echo "0")
    TOTAL_TESTS=$((PASSED_TESTS + FAILED_TESTS))

    if [ $TOTAL_TESTS -gt 0 ]; then
        SUCCESS_RATE=$((PASSED_TESTS * 100 / TOTAL_TESTS))
    else
        SUCCESS_RATE=0
    fi

    # Create JSON summary
    cat > "${TEST_RESULTS_DIR}/summary.json" << EOF
{
  "module_name": "${MODULE_NAME}",
  "timestamp": "${TIMESTAMP}",
  "total_tests": ${TOTAL_TESTS},
  "passed_tests": ${PASSED_TESTS},
  "failed_tests": ${FAILED_TESTS},
  "success_rate": ${SUCCESS_RATE},
  "exit_code": ${TEST_EXIT_CODE}
}
EOF

    echo -e "${BLUE}📊 Test Results Summary:${NC}"
    echo -e "  Total Tests: ${TOTAL_TESTS}"
    echo -e "  Passed: ${GREEN}${PASSED_TESTS}${NC}"
    echo -e "  Failed: ${RED}${FAILED_TESTS}${NC}"
    echo -e "  Success Rate: ${SUCCESS_RATE}%"
    echo -e "  Results: ${TEST_RESULTS_DIR}/summary.json"
fi

# Cleanup if requested
if [ "${CLEANUP_AFTER_TESTS}" = "true" ]; then
    echo -e "\n${YELLOW}🧹 Cleaning up test data...${NC}"
    # Add any cleanup commands here
fi

echo -e "\n${BLUE}🏁 Integration tests completed!${NC}"

if [ ${TEST_EXIT_CODE} -eq 0 ]; then
    echo -e "${GREEN}✅ All ${MODULE_NAME^} integration tests passed successfully!${NC}"
else
    echo -e "${RED}❌ Some ${MODULE_NAME^} integration tests failed. Check ${TEST_RESULTS_DIR}/test_output.log for details${NC}"
fi

exit ${TEST_EXIT_CODE}