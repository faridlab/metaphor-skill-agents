//! Test Setup Manager for {{ module_name|title }} Module
//!
//! Handles test database setup, connection management, and cleanup operations
//! following Backbone Framework testing patterns.

use async_trait::async_trait;
use sqlx::{PgPool, postgres::PgPoolOptions};
use std::sync::Arc;
use anyhow::Result;

use crate::framework::TestError;

/// Manages test infrastructure setup and cleanup
pub struct TestSetupManager {
    database_url: String,
    pool: Option<Arc<PgPool>>,
    cleanup_ids: Vec<String>,
}

impl TestSetupManager {
    /// Create a new test setup manager
    pub fn new(database_url: impl Into<String>) -> Self {
        Self {
            database_url: database_url.into(),
            pool: None,
            cleanup_ids: Vec::new(),
        }
    }

    /// Initialize database connection
    pub async fn setup(&mut self) -> Result<(), TestError> {
        let pool = PgPoolOptions::new()
            .max_connections(10)
            .connect(&self.database_url)
            .await
            .map_err(|e| TestError::DatabaseError(e.to_string()))?;

        self.pool = Some(Arc::new(pool));

        // Ensure database is in clean state
        self.cleanup_existing_test_data().await?;

        tracing::info!("✅ Database connection established for {{ module_name }} tests");
        Ok(())
    }

    /// Get database pool
    pub fn pool(&self) -> Result<Arc<PgPool>, TestError> {
        self.pool.clone()
            .ok_or_else(|| TestError::ConfigError("Database not initialized".to_string()))
    }

    /// Register ID for cleanup
    pub fn register_cleanup_id(&mut self, id: String) {
        self.cleanup_ids.push(id);
    }

    /// Clean up test data
    pub async fn cleanup(&mut self) -> Result<(), TestError> {
        if self.cleanup_ids.is_empty() {
            tracing::info!("No test data to cleanup");
            return Ok(());
        }

        tracing::info!("🧹 Cleaning up {} test records", self.cleanup_ids.len());

        let pool = self.pool()?;

        // Clean up test data (this would be customized per module)
        {% for entity in entities %}
        if let Err(e) = self.cleanup_{{ entity }}_data(&pool).await {
            tracing::warn!("Failed to cleanup {{ entity }} data: {}", e);
        }
        {% endfor %}

        self.cleanup_ids.clear();

        if let Some(pool) = self.pool.take() {
            pool.close().await;
        }

        tracing::info!("✅ Test cleanup completed");
        Ok(())
    }

    {% for entity in entities %}
    /// Clean up {{ entity }} test data
    async fn cleanup_{{ entity }}_data(&self, pool: &PgPool) -> Result<(), anyhow::Error> {
        let ids: Vec<String> = self.cleanup_ids.iter()
            .filter(|id| id.starts_with("{{ entity }}_"))
            .map(|id| id.split('_').last().unwrap_or(id).to_string())
            .collect();

        if !ids.is_empty() {
            let query = format!("DELETE FROM {{ entity|lower }}s WHERE id = ANY($1)");
            sqlx::query(&query)
                .bind(&ids)
                .execute(pool)
                .await?;
        }

        Ok(())
    }
    {% endfor %}

    /// Clean up any existing test data from previous runs
    async fn cleanup_existing_test_data(&self) -> Result<(), TestError> {
        let pool = self.pool()?;

        {% for entity in entities %}
        if let Err(e) = self.cleanup_existing_{{ entity }}_data(&pool).await {
            tracing::warn!("Failed to cleanup existing {{ entity }} data: {}", e);
        }
        {% endfor %}

        Ok(())
    }

    {% for entity in entities %}
    async fn cleanup_existing_{{ entity }}_data(&self, pool: &PgPool) -> Result<(), anyhow::Error> {
        // Delete {{ entity }} records created during tests
        let result = sqlx::query!("DELETE FROM {{ entity|lower }}s WHERE email LIKE '%test%' OR username LIKE '%test%' OR name LIKE '%test%'")
            .execute(pool)
            .await?;

        if result.rows_affected() > 0 {
            tracing::info!("Cleaned up {} existing {{ entity }} test records", result.rows_affected());
        }

        Ok(())
    }
    {% endfor %}
}

#[async_trait]
impl Drop for TestSetupManager {
    fn drop(&mut self) {
        // Note: This is a synchronous Drop implementation
        // In async context, we rely on explicit cleanup() calls
        tracing::debug!("TestSetupManager dropped - ensure cleanup() was called");
    }
}